# Pulsar Patch — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env*`
# (already gitignored). Every var here is VITE_-prefixed, which means it ships
# to the browser — so ONLY put values that are safe to be public.
#
# Rule of thumb: if a key would let someone do something privileged on your
# behalf (a Supabase service_role/secret key, a Shopify Admin API token, a
# payment secret), it must NOT go here. Those belong on a server only.

# ── Supabase (admin auth + reviews database) ─────────────────────────────
# The URL and the PUBLISHABLE key are safe to expose: Row Level Security
# controls what the publishable key can actually do. Do NOT use the secret
# (sb_secret_...) key here — it bypasses RLS.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Review screening ─────────────────────────────────────────────────────
# Just an inbox address (not a secret). Personal backup inbox is hardcoded.
VITE_ADMIN_EMAIL=pulsarpatch@gmail.com

# ── Form / email delivery (Google Apps Script web app) ───────────────────
# Public endpoint URL. Recipients are locked down server-side in the script.
VITE_LEADS_ENDPOINT=https://script.google.com/macros/s/XXXXXXXX/exec

# ── Shopify (Storefront API — public, read-only, scoped) ─────────────────
# The Storefront token is designed to be public. NEVER put an Admin API
# token (shpat_...) here — that one is secret and server-only.
VITE_SHOPIFY_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_public_storefront_token
# Map our catalog ids -> Shopify PRODUCTS (the number in a product's admin URL,
# .../products/8123456789). Best for single-variant products; the site finds
# their one variant automatically and reads its live price.
VITE_SHOPIFY_PRODUCTS={"single":"","3pack":"","6pack":"","kickback":"","party":"","sub-weekend":"","sub-social":"","sub-jugular":""}
# Advanced/alternative: map ids -> specific VARIANT ids (.../variants/44823905921)
# when a product has multiple variants. Takes precedence over PRODUCTS.
VITE_SHOPIFY_VARIANTS={}
